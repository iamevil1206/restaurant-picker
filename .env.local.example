# Naver Cloud Platform - Maps (JavaScript API v3)
# https://console.ncloud.com → AI·NAVER API → Maps → 애플리케이션 등록
# 서비스 환경 등록에 http://localhost:3000 추가 필수
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# Naver Developers - Search Local API (보조 소스, 위치 기반 아님)
# https://developers.naver.com/apps → 검색 API 사용 신청
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# Kakao Developers - REST API (위치 기반 검색 + 주소검색의 주력 소스)
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
# 일 300,000건 무료, 카드 등록 불필요
KAKAO_REST_API_KEY=

# Google Cloud - Places API (New) - 선택
# https://console.cloud.google.com → APIs & Services → Enable "Places API (New)"
# 키에 HTTP referer 제한 권장. 카드 등록 필요 (월 $200 무료 크레딧)
GOOGLE_PLACES_API_KEY=
